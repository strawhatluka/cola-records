{
  "name": "cola-records",
  "version": "1.0.6",
  "productName": "Cola Records",
  "description": "Cola Records - GitHub contribution tracker with integrated IDE",
  "main": ".vite/build/index.js",
  "scripts": {
    "start": "electron-forge start",
    "start:clean": "npm run clean && electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "build:win": "electron-forge make --platform win32",
    "build:mac": "electron-forge make --platform darwin",
    "build:linux": "electron-forge make --platform linux",
    "release": "electron-forge publish",
    "release:draft": "electron-forge publish --dry-run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .vite out",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "postinstall": "electron-rebuild"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lukadfagundes/cola-records.git"
  },
  "keywords": [],
  "author": {
    "name": "Luka Fagundes",
    "email": "luka@sunny-stack.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lukadfagundes/cola-records/issues"
  },
  "homepage": "https://github.com/lukadfagundes/cola-records#readme",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
