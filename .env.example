# Cola Records Environment Configuration
# Copy this file to .env and fill in your values

# ====================
# Required Configuration
# ====================

# GitHub Fine Grained Personal Access Token
# Required Permissions:
#   - Contents: Read/Write
#   - Pull Requests: Read/Write
#   - Metadata (Required): Read Only
#   - Issues: Read/Write
# Get yours at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# ====================
# Optional Configuration
# ====================

# Application Environment
# Values: development, production
NODE_ENV=development

# Default directory for cloning repositories
# Leave empty to use system default
DEFAULT_CLONE_PATH=

# GitHub API Settings
# Timeout in milliseconds for API requests
GITHUB_API_TIMEOUT=30000

# Cache time-to-live in hours for GitHub API responses
CACHE_TTL_HOURS=24

# Maximum retry attempts for failed API requests
MAX_RETRIES=3

# Auto-fetch settings
# Enable automatic fetching of repository updates
AUTO_FETCH_ENABLED=true

# Logging
# Values: debug, info, warn, error
LOG_LEVEL=info

# ====================
# Optional Integrations
# ====================

# Spotify Integration
# OAuth is handled in-app via Settings > API tab
# No environment variables needed - configure in Settings

# Discord Integration
# Token is managed securely in-app via Settings > API tab
# No environment variables needed - configure in Settings
